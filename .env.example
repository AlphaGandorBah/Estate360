# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DEBUG=True
SECRET_KEY=changeme
ALLOWED_HOSTS=localhost,127.0.0.1
JWT_SIGNING_KEY=changeme
# Keep true when using the bundled HTTPS gateway; set false only for HTTP-only
# localhost development.
JWT_REFRESH_COOKIE_SECURE=True
# Hostname or LAN IP served by the bundled HTTPS reverse proxy.
HTTPS_HOST=localhost
# Enable only when Django is reached through that trusted reverse proxy.
TRUST_PROXY_HEADERS=True

# Postgres
DATABASE_URL=postgres://estate360:estate360@localhost:5432/estate360
# Optional: point containerized Django at an existing host database. Omit this
# line to use Compose's own `db` service.
# COMPOSE_DATABASE_URL=postgres://estate360:estate360@host.docker.internal:5432/estate360

# Redis
REDIS_URL=redis://localhost:6379

# Object storage (MinIO in dev)
MEDIA_S3_ENDPOINT=http://localhost:9000
MEDIA_S3_ACCESS_KEY=minioadmin
MEDIA_S3_SECRET_KEY=minioadmin
MEDIA_S3_BUCKET=estate360
MEDIA_S3_REGION=us-east-1
# Public HTTPS endpoint embedded in presigned URLs. Use the same hostname or
# LAN IP as HTTPS_HOST when other devices need access.
MEDIA_HOST=https://localhost:9443

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_FROM=no-reply@estate360.local

# ClamAV
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://localhost
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://localhost

# Admin bootstrap
ADMIN_EMAIL=admin@estate360.local
ADMIN_PASSWORD=changeme

# Chatbot LLM — optional override; defaults to apps/chatbot/models/<file>,
# populated by `make chatbot-model`. Leave unset to use that default.
# CHATBOT_MODEL_PATH=
